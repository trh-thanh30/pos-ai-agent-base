{
  "extends": "@repo/typescript-config/react-library.json",
  "compilerOptions": {
    "outDir": "dist",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@repo/*": ["../*"],
      "@repo/design-system/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "dist",
    "build",
    "node_modules",
    "src/components/layout/dashboard-layout.tsx",
    "src/components/shared/chart-screen/bar-chart.tsx",
    "src/components/shared/chart-screen/line-chart.tsx",
    "src/components/shared/item/item-low-stock.tsx",
    "src/components/shared/item/item-notification.tsx",
    "src/components/shared/item/item-top-products.tsx"
  ]
}
