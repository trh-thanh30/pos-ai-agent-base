  return_status order_return_status @default(REQUESTED)
  total         Decimal             @db.Decimal(15, 2) // Tổng tiền hàng trả
  suggest_total Decimal             @db.Decimal(15, 2) // Tổng tiền đề xuất hoàn trả (dựa trên item trả)
  items_length  Int

  items    OrderReturnItem[]
  store    Store                @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
