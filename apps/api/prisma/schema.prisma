// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum user_role {
  ADMIN // Admin is the super user of the system
  STAFF // Staff is a user who can manage the system
  USER // User is a user who can use the system
}

enum StoreMemberRole {
  OWNER
  MEMBER
}

enum user_status {
  ACTIVE // Active is a user who is active in the system
  INACTIVE // Inactive is a user who is inactive in the system
  SUSPENDED // Suspended is a user who is suspended in the system
}

enum order_status {
  PENDING // thanh toán đang chờ xử lý
  PROCESSING // XỬ LÝ
  COMPLETED // hoàn thành
  CANCELLED // bị hủy
  RETURNED // trả 
  OVERAGE // quá trình
}

enum order_return_status {
  REQUESTED // Khách yêu cầu trả hàng
  REFUNDED // Đã hoàn tiền
  CANCELLED // Huỷ yêu cầu trả
}

enum order_return_type {
  NONE // Chưa hoàn trả
  FULL // Trả toàn bộ đơn hàng
  PARTIAL // Trả một phần đơn hàng
}

enum order_item_return_reason {
  // Nhóm lỗi Shop/Sản phẩm
  PRODUCT_DEFECT // Hàng lỗi/hỏng
  WRONG_PRODUCT // Giao sai hàng
  NOT_AS_DESCRIBED // Khác mô tả
  EXPIRED // Hết hạn
  INCOMPLETE // Thiếu phụ kiện
  POOR_QUALITY // Chất lượng kém

  // Nhóm vận chuyển
  SHIPPING_DAMAGE // Hư hỏng do vận chuyển
  LATE_DELIVERY // Giao trễ

  // Nhóm khách hàng
  CHANGE_OF_MIND // Đổi ý/Không thích nữa
  SIZE_UNFIT // Không vừa (Size)
  ACCIDENTAL_ORDER // Đặt nhầm
  BETTER_PRICE // Tìm thấy giá rẻ hơn

  // Khác
  OTHER // Lý do khác
  UNKNOWN // Không xác định
}

enum inventory_status {
  ACTIVE
  INACTIVE
  SOLD
}

enum product_status {
  ACTIVE
  INACTIVE
  SOLD
}

enum product_type {
  PURCHASE // được tạo do nhập hàng ...
  QUICK_CREATE // được tạo do user tạo nhanh bằng tay
  //... tạo bằng đặt hàng, ....
}

enum provider_type {
  GOOGLE
  FACEBOOK
  GITHUB
  MANUAL
}

enum stock_movement_type {
  // Adjust the stock of a product by adding or subtracting the stock (for example: add 10 units to the stock)
  ADJUSTMENT
  // Purchase the stock of a product from a supplier to the store (for example: purchase 10 units of a product from a supplier) 
  PURCHASE
  // Sale the stock of a product to a customer (for example: sell 10 units of a product to a customer)
  SALE
  // Return the stock of a product from a customer to the supplier (for example: return 10 units of a product to the supplier)
  RETURN_PURCHASE
  // Return the stock of a product from the customer to the supplier (for example: return 10 units of a product to the customer)
  RETURN_SALE
  // Transfer the stock of a product from one store to another store (for example: transfer 10 units of a product from one store to another store)
  TRANSFER_IMPORT
  // 
  TRANSFER_EXPORT
}

enum payment_method {
  CASH // Tiền mặt (thanh toán trực tiếp)
  CREDIT_CARD // Thẻ tín dụng
  DEBIT_CARD // Thẻ ghi nợ
  BANK_TRANSFER // Chuyển khoản ngân hàng
  DIGITAL_WALLET // Ví điện tử (MoMo, ZaloPay, etc.)
}

// Loại giao dịch tài chính
enum transaction_type {
  RECEIPT // Phiếu thu (tiền vào)
  PAYMENT // Phiếu chi (tiền ra)
}

// Nguồn phát sinh giao dịch
enum transaction_source {
  SALE // Bán hàng
  PURCHASE // Nhập hàng
  ORDER_RETURN // Trả hàng (khách trả)
  PURCHASE_RETURN // Trả hàng nhập (trả NCC)
  CUSTOMER_DEBT // Thu công nợ khách hàng
  SUPPLIER_DEBT // Trả công nợ NCC
  OTHER_INCOME // Thu khác
  OTHER_EXPENSE // Chi khác
  OPENING_BALANCE // Số dư đầu kỳ
}

enum TransactionReferenceType {
  ORDER
  PURCHASE_ORDER
  ORDER_RETURN
  PURCHASE_RETURN
  OTHER
}

// Trạng thái giao dịch
enum transaction_status {
  PENDING // Chờ xác nhận
  CONFIRMED // Đã xác nhận
  CANCELLED // Đã hủy
}

enum contact_type {
  CUSTOMER
  SUPPLIER
  OTHER
  STORE_MEMBER
}

enum supplier_status {
  ACTIVE
  INACTIVE
  DELETE
}

enum payment_status {
  UNPAID // Chưa thanh toán (đơn hàng mới tạo)
  PARTIAL // Thanh toán một phần (khách hàng đã thanh toán một phần)
  PAID // Đã thanh toán đầy đủ (thanh toán hoàn toàn)
  OVERDUE // Quá hạn thanh toán (cho đơn hàng nợ/trả sau)
}

// purchase_order_status: Trạng thái của đơn đặt hàng nhập hàng (Purchase Order)
// Theo dõi quy trình xử lý đơn hàng mua từ nhà cung cấp
enum purchase_order_status {
  PENDING // Đang chờ duyệt (chờ quản lý phê duyệt)
  RECEIVED // Đã nhận hàng đầy đủ (đã nhận toàn bộ hàng đặt)
}

enum asset_type {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  OTHER
}

enum asset_access_type {
  PUBLIC   /// Ai cũng có thể truy cập (qua CDN)
  PRIVATE  /// Chỉ user có quyền mới truy cập
  TEMP     /// File tạm, có thời gian hết hạn
}
enum purchase_return_status {
  DRAFT
  COMPLETED
  CANCELLED
}

enum FeedbackStatus {
  PROCESSING
  REJECTED
  COMPLETED
}

enum SatisfactionRating {
  POOR
  FAIR
  GOOD
  EXCELLENT
}

enum CommenterType {
  USER
  ADMIN
}

enum notification_type {
  SYSTEM       // Tự động bởi hệ thống
  ADMIN        // Thủ công bởi Admin
  ORDER        // Liên quan đến đơn hàng
  INVENTORY    // Liên quan đến kho/tồn kho
  FINANCE      // Liên quan đến tài chính
  SECURITY     // Thao tác nhạy cảm
}

enum notification_target_type {
  ALL          // Toàn bộ user
  ROLE         // Theo role
  USER         // Theo user cụ thể
}

/**
 * User model
 * User is a model that represents the user of the system
 * It is used to track the user of the system
 * User has many products
 */
model User {
  id            String         @id @default(uuid()) @db.Uuid
  provider_id   String?
  provider      provider_type? @default(MANUAL)
  email         String         @unique
  password      String?
  username      String         @unique
  role          user_role      @default(USER)
  status        user_status    @default(ACTIVE)
  is_verified   Boolean        @default(false)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refresh_token String?

  // code 
  verification_code           String?
  verification_code_expired   DateTime?
  password_reset_code         String?
  password_reset_code_expired DateTime?

  // relations
  ownedStores              Store[] // user is owner of the store
  memberships              StoreMember[] // user is member of the store
  products_created         Product[] // user is creator of the product
  orders_cashier           Order[] // user is cashier of the order
  order_return_creator     OrderReturn[]
  created_purchases        PurchaseOrder[]  @relation("PurchaseOrderCreatedBy")
  approved_purchases       PurchaseOrder[]  @relation("PurchaseOrderApprovedBy")
  created_purchases_return PurchaseReturn[]
  assets                   Asset[]

  // feedback relations
  feedbacks_submitted Feedback[]        @relation("UserFeedback")
  feedbacks_assigned  Feedback[]        @relation("AdminFeedback")
  feedback_comments   FeedbackComment[]

  // notification relations
  notifications_created  Notification[]     @relation("NotificationCreator")
  user_notifications     UserNotification[] @relation("UserNotifications")

  // indexes
  @@index([role, status])
  @@map("user")
}

/**
 * Store model
 * Store is a model that represents the store of the system
 * It is used to track the store of the system
 * Store has many products
 * Store has many members
 */
model Store {
  id            String   @id @default(uuid()) @db.Uuid
  owner_id      String   @db.Uuid
  name          String
  description   String?
  phone_number  String?
  city          String?
  state         String?
  address       String?
  subdomain     String?  @unique @db.VarChar(100)
  retail_config Json?    @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // relations
  owner              User               @relation(fields: [owner_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  members            StoreMember[]
  products           Product[]
  categories         Category[]
  tags               Tag[]
  customer           Customer[]
  statistics_daily   StatisticsDaily[]
  orders             Order[]
  order_returns      OrderReturn[]
  store_payment      StorePayment[] // Thông tin thanh toán
  store_reward_point StoreRewardPoint[]
  supplier           Supplier[]
  purchase_orders    PurchaseOrder[]
  purchase_return    PurchaseReturn[]
  variant_stock      VariantStock[]
  cash_transactions  CashTransaction[]
  cash_book_entries  CashBookEntry[]
  bundles            Bundle[]
  assets             Asset[]
  feedbacks          Feedback[]

  // indexes
  @@index([owner_id])
  @@index([name])
  @@map("store")
}

// StorePayment: Quản lý thông tin thanh toán của cửa hàng
// Lưu trữ chi tiết tài khoản ngân hàng và QR code thanh toán
model StorePayment {
  // ID và thông tin cơ bản
  id       String @id @default(uuid()) @db.Uuid // ID duy nhất (UUID)
  store_id String @db.Uuid // ID cửa hàng (foreign key)

  // Thông tin ngân hàng
  bank_code           String // Mã ngân hàng (ví dụ: "VCCB" cho Vietcombank)
  bank_name           String // Tên ngân hàng
  bank_account_number String // Số tài khoản ngân hàng
  bank_account_name   String // Tên chủ tài khoản
  bank_qr_image_url   String? // URL hình ảnh QR code thanh toán
  note                String?
  // Thời gian
  createdAt           DateTime @default(now()) // Ngày tạo
  updatedAt           DateTime @updatedAt // Ngày cập nhật lần cuối
  updated_by          String?  @db.Uuid // ID người cập nhật lần cuối

  // Relations
  store Store @relation(fields: [store_id], references: [id], onDelete: Cascade) // Cửa hàng

  // Indexes
  @@index([store_id]) // Index cửa hàng
  @@map("store_payment") // Tên bảng trong database
}

// StoreRewardPoint: Quản lý cấu hình điểm thưởng của cửa hàng
// Xác định tỷ lệ chuyển đổi điểm thưởng thành tiền mặt
model StoreRewardPoint {
  // ID
  id String @id @default(uuid()) @db.Uuid // ID duy nhất (UUID)

  // Thông tin cơ bản
  store_id     String  @db.Uuid // ID cửa hàng (foreign key)
  convert_to   String  @default("VND") @db.VarChar(255) // Đơn vị tiền tệ (VND, USD, etc.)
  convert_rate Int     @default(100000) // Tỷ lệ: 100000 đơn vị tiền = 1 điểm thưởng
  point_value  Int     @default(5000) // Giá trị 1 điểm thưởng (đơn vị tiền)
  description  String? @db.VarChar(255) // Mô tả chính sách điểm
  is_apply     Boolean @default(false)

  // Thời gian
  createdAt DateTime @default(now()) // Ngày tạo
  updatedAt DateTime @updatedAt // Ngày cập nhật lần cuối

  // Relations
  stores Store @relation(fields: [store_id], references: [id], onDelete: Cascade) // Cửa hàng

  // Indexes
  @@index([store_id]) // Index cửa hàng
  @@map("store_reward_point") // Tên bảng trong database
}

/**
 * Store member model
 * Store member is a model that represents the member of a store
 * It is used to track the member of a store
 * Store member has one store
 * Store member has one user
 */
model StoreMember {
  storeId     String @db.Uuid
  userId      String @db.Uuid
  name        String @default("")
  email       String @default("")
  total_order Int    @default(0)

  role      StoreMemberRole @default(MEMBER)
  createdAt DateTime        @default(now())

  // relations
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // indexes
  @@id([storeId, userId])
  @@index([userId])
  @@map("store_member")
}

/**
 * Order customer model
 * Order customer is a model that represents the customer of an order
 * It is used to track the customer of an order
 * Order customer has one order
 * Order customer has one user
 */
model Customer {
  id            String        @unique @default(uuid()) @db.Uuid
  store_id      String        @db.Uuid
  name          String
  phone         String?
  email         String?
  address       String?
  city          String?
  state         String?
  zip           String?
  country       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  // relations
  store         Store         @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  orders        Order[]
  order_returns OrderReturn[]

  // indexes
  @@id([store_id, id])
  @@index([store_id])
  @@map("customer")
}

// Supplier: Quản lý thông tin nhà cung cấp hàng hoá
// Lưu trữ thông tin liên hệ, địa chỉ và lịch sử mua hàng
model Supplier {
  // ID
  id              String           @id @default(uuid()) @db.Uuid // ID duy nhất (UUID)
  // Thông tin cơ bản
  store_id        String           @db.Uuid // ID cửa hàng (multi-tenant isolation)
  code            String? // Mã nhà cung cấp (tự tạo, dễ nhớ)
  name            String // Tên nhà cung cấp
  contact_person  String? // Tên người liên hệ
  address         String?
  tax_code        String?
  email           String?          @default("") // Email liên hệ
  phone           String? // Số đcdthuế
  bank_account    Json? // Thông tin tài khoản ngân hàng (JSON object)
  notes           String? // Ghi chú thêm
  status          supplier_status  @default(ACTIVE) // Có còn hoạt động không
  total_purchased Decimal          @default(0) @db.Decimal(15, 2) // Tổng giá trị hàng đã mua từ nhà cung cấp này (dùng để phân tích)
  // Thời gian
  createdAt       DateTime         @default(now()) // Ngày tạo
  updatedAt       DateTime         @updatedAt // Ngày cập nhật lần cuối
  deletedAt       DateTime?
  // Relations
  store           Store            @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: Cascade) // Cửa hàng
  purchase_orders PurchaseOrder[] // Danh sách đơn hàng mua từ nhà cung cấp này
  purchase_return PurchaseReturn[] // Danh sách đơn hàng trả đến nhà cung cấp này

  // Unique Constraints
  @@unique([store_id, code]) // Mã nhà cung cấp không được trùng trong 1 cửa hàng
  // Indexes
  @@index([store_id, status]) // Index nhà cung cấp hoạt động
  @@map("supplier") // Tên bảng trong database
}

/**
 * Product model
 * Product is a model that represents the product of a product
 * It is used to track the product of a product
 * Product has many inventories
 * Product has one user
 */
model Product {
  id                     String               @id @default(uuid()) @db.Uuid
  store_id               String               @db.Uuid
  name                   String
  sku                    String
  baseUnit               String // Đơn vị gốc (VD: "cái", "ml"). Immutable.
  image_url              String?
  description            String?
  product_status         product_status       @default(ACTIVE)
  meta                   Json                 @default("{}")
  source_type            product_type         @default(QUICK_CREATE)
  is_set_default_variant Boolean?             @default(true)
  is_deleted             Boolean?             @default(false)
  created_by             String               @db.Uuid
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  deletedAt              DateTime?
  // relations
  created_by_user        User                 @relation(fields: [created_by], references: [id], onDelete: Cascade, onUpdate: Cascade)
  store                  Store                @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  categories             Category[]
  variant                Variant[]
  tags                   Tag[]
  order_item             OrderItem[]
  order_return_item      OrderReturnItem[]
  purchase_order_items   PurchaseOrderItem[]
  purchase_return_items  PurchaseReturnItem[]

  @@unique([store_id, sku])
  // indexes
  @@index([store_id, sku])
  @@index([created_by, product_status, name])
  @@map("product")
}

model Variant {
  id                    String               @id @default(uuid()) @db.Uuid
  product_id            String               @db.Uuid
  sku                   String
  barcode               String?
  name                  String
  price                 Int                  @default(0)
  cost                  Int?                 @default(0)
  product               Product              @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  conversions           UnitConversion[]
  order_item            OrderItem[]
  order_return_item     OrderReturnItem[]
  purchase_order_items  PurchaseOrderItem[]
  purchase_return_items PurchaseReturnItem[]
  variant_stocks        VariantStock[]
  stock_movements       StockMovement[]
  bundle_items          BundleItem[]
  // @@unique([store_id, sku])
  // @@unique([store_id, barcode])
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@unique([product_id, name])
  @@index([product_id, name])
  @@map("variant")
}

model VariantStock {
  id         String @id @default(uuid()) @db.Uuid
  store_id   String @db.Uuid
  variant_id String @db.Uuid
  onHand     Int    @default(0) // Tồn kho thực tế
  reserved   Int?   @default(0) // Tồn đã giữ chỗ (đơn chưa nhập, chưa xuất)
  damaged    Int?   @default(0) // Tồn hỏng / lock kiểm kê

  createdAt DateTime @default(now())
  updateAt  DateTime @updatedAt

  variant Variant @relation(fields: variant_id, references: id, onDelete: Cascade, onUpdate: Cascade)
  store   Store   @relation(fields: [store_id], references: [id])

  @@unique([variant_id, store_id])
  @@map("variant_stocks")
}

model UnitConversion {
  id        String  @id @default(uuid()) @db.Uuid
  name      String
  factor    Int
  variantId String  @db.Uuid
  variant   Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, name])
  @@map("unit_conversions")
}

model ProductTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  barcode     String   @unique
  price       Int      @default(0)
  cost        Int      @default(0)
  image_url   String?
  description String?
  meta        Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("product_template")
}

/**
 * Category model
 * Category is a model that represents the category of a product
 * It is used to track the category of a product
 */
model Category {
  id          String    @id @default(uuid()) @db.Uuid
  store_id    String    @db.Uuid
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // relations
  store       Store     @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  products    Product[]

  @@unique([store_id, name])
  // indexes
  @@index([store_id])
  @@index([name])
  @@map("category")
}

/**
 * Tag model
 * Tag is a model that represents the tag of a product
 * It is used to track the tag of a product
 */
model Tag {
  id          String    @id @default(uuid()) @db.Uuid
  store_id    String    @db.Uuid
  name        String
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // relations
  store       Store     @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  products    Product[]

  @@unique([store_id, name])
  // indexes
  @@index([store_id])
  @@index([name])
  @@map("tag")
}

model StockMovement {
  id         String              @id @default(uuid()) @db.Uuid
  variant_id String              @db.Uuid
  quantity   Int
  type       stock_movement_type
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  // relations
  variants   Variant             @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // indexes
  @@index([variant_id])
  @@map("stock_movement")
}

/**
 * Order model
 * Order is a model that represents the order of a product
 * It is used to track the order of a product
 */
model Order {
  id                  String         @id @default(uuid()) @db.Uuid
  code                String?
  cashier_id          String         @db.Uuid
  customer_id         String?        @db.Uuid
  customer_name       String?
  store_id            String         @db.Uuid
  // amount
  // the total customer pay for the order
  customer_pay_amount Int            @default(0)
  // the total need to return or customer to pay for total amount 
  change_amount       Int            @default(0)
  // the total amount of the order before discount and tax: subtotal_amount = quantity * price
  subtotal_amount     Int            @default(0)
  // the total amount of the order after discount: discount_amount = subtotal_amount * discount_rate
  discount_amount     Int            @default(0)
  // the total amount of the order after tax: tax_amount = subtotal_amount * tax_rate
  tax_amount          Int            @default(0)
  // the total amount of the order after discount and tax: total_amount = subtotal_amount - discount_amount + tax_amount
  total_amount        Int            @default(0)
  // payment
  payment_method      payment_method @default(CASH)
  status              order_status   @default(PENDING)
  // date
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  // relations
  store               Store          @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cashier             User           @relation(fields: [cashier_id], references: [id], onDelete: Cascade)
  customer            Customer?      @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  order_return        OrderReturn[]
  order_item          OrderItem[]

  // indexes
  @@index([cashier_id])
  @@index([customer_id])
  @@index([status])
  @@map("order")
}

/**
 * Order item model
 * Order item is a model that represents the item of an order
 * It is used to track the item of an order
 */
model OrderItem {
  id                String            @id @default(uuid()) @db.Uuid
  order_id          String            @db.Uuid
  variant_id        String            @db.Uuid
  product_id        String            @db.Uuid
  quantity          Int               @default(0)
  quantity_return   Int?              @default(0) // snap shot các lần trả
  discount_rate     Decimal?          @default(0)
  tax_rate          Decimal?          @default(0)
  price             Int               @default(0)
  total             Int               @default(0)
  meta              Json              @default("{}")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  // relations
  order_item_return OrderReturnItem[]
  order             Order             @relation(fields: [order_id], references: [id], onDelete: Cascade)
  variant           Variant           @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product           Product           @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // indexes
  @@index([order_id])
  @@index([variant_id])
  @@index([product_id])
  @@map("order_item")
}

model OrderReturn {
  id          String  @id @default(uuid()) @db.Uuid
  order_id    String  @db.Uuid
  store_id    String  @db.Uuid
  created_id  String  @db.Uuid // ID người tạo đơn hàng
  customer_id String? @db.Uuid

  order_number        String
  order_return_number String

  customer_name  String?
  customer_phone String?

