// ===============================
// PURCHASE ORDER - HÓA ĐƠN NHẬP HÀNG
// ===============================
// PurchaseOrder: Đơn hàng mua từ nhà cung cấp
// Core entity cho quản lý nhập hàng, từ draft đến nhận hàng
model PurchaseOrder {
  // ID
  id String @id @default(uuid()) @db.Uuid // ID duy nhất (UUID)

  // Thông tin cơ bản
  store_id     String @db.Uuid // ID cửa hàng (multi-tenant isolation)
  order_number String // mã phiếu nhập (auto-generated)

  supplier_id   String    @db.Uuid // ID nhà cung cấp
  supplier_code String?
  supplier_name String    @default("")
  // Thời gian
  order_date    DateTime  @default(now()) // Ngày đặt hàng
  expected_date DateTime? // Ngày dự kiến nhận hàng
  received_date DateTime? // Ngày thực tế nhận hàng

  // Trạng thái
  status purchase_order_status @default(PENDING) // Trạng thái đơn hàng

  // Tài chính
  subtotal        Decimal  @default(0) @db.Decimal(15, 2) // Tổng tiền hàng (trước chiết khấu/thuế)
  discount_amount Decimal  @default(0) @db.Decimal(15, 2) // Tổng chiết khấu
  tax_amount      Decimal  @default(0) @db.Decimal(15, 2) // Tiền thuế
  shipping_fee    Decimal? @default(0) @db.Decimal(15, 2) // Phí vận chuyển
  total           Decimal  @default(0) @db.Decimal(15, 2) // Tổng cộng
  paid_amount     Decimal  @default(0) @db.Decimal(15, 2) // Đã thanh toán

  // Thanh toán
  payment_method payment_method? // Phương thức thanh toán
  payment_status payment_status  @default(UNPAID)

  // Ghi chú
  notes String? // Ghi chú đơn hàng

  // Quản lý
  created_by  String    @db.Uuid // ID người tạo đơn hàng
  approved_by String?   @db.Uuid // ID người duyệt đơn hàng
  approved_at DateTime? // Thời gian duyệt

  // Thời gian
  createdAt DateTime @default(now()) // Ngày tạo
  updatedAt DateTime @updatedAt // Ngày cập nhật lần cuối

  // Relations
  store            Store               @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: Cascade) // Cửa hàng
  supplier         Supplier            @relation(fields: [supplier_id], references: [id], onDelete: Restrict, onUpdate: Cascade) // Nhà cung cấp
  creator          User                @relation("PurchaseOrderCreatedBy", fields: [created_by], references: [id], onDelete: Restrict, onUpdate: Cascade) // Người tạo
  approver         User?               @relation("PurchaseOrderApprovedBy", fields: [approved_by], references: [id], onDelete: Restrict, onUpdate: Cascade) // Người duyệt
  items            PurchaseOrderItem[] // Chi tiết các sản phẩm trong đơn hàng
  payments         PurchasePayment[] // Lịch sử thanh toán
  purchase_returns PurchaseReturn[]

  // Unique Constraints
  @@unique([store_id, order_number]) // Số hóa đơn không được trùng trong 1 cửa hàng
  // Indexes
  @@index([store_id, status, order_date]) // Index truy vấn theo cửa hàng, trạng thái, ngày
  @@index([supplier_id, status]) // Index truy vấn theo nhà cung cấp
  @@map("purchase_order") // Tên bảng trong database
}

// PurchaseOrderItem: Chi tiết sản phẩm trong đơn hàng mua
// Line items của mỗi purchase order
model PurchaseOrderItem {
  // ID
  id String @id @default(uuid()) @db.Uuid // ID duy nhất (UUID)

  // Foreign Keys
  purchase_order_id String @db.Uuid // ID đơn hàng mua
  product_id        String @db.Uuid // ID sản phẩm
  variant_id        String @db.Uuid
  // unit_id           String  @db.Uuid // ID đơn vị mua

  // Thông tin mua
  item_name         String   @default("")
  quantity          Decimal  @db.Decimal(10, 2) // Số lượng mua
  quantity_returned Decimal? @db.Decimal(10, 2) // snap shot các lần trả
  unit              String? // VD: "Thùng"      
  applied_factor    Int? // VD: 24 (Base Unit thì = 1)
  total_base_qty    Int? // = inputQuanity * appliedFactor (VD : 48)
  unit_cost         Decimal  @db.Decimal(15, 2) // giá nhập 
  discount_rate     Decimal  @default(0) @db.Decimal(15, 2) // Chiết khấu % (0.1 = 0.1%)
  tax_rate          Decimal  @default(0) @db.Decimal(15, 2) // Thuế % (0.1 = 0.1%)

  // tiền sau tính toán
  subtotal        Decimal @default(0) @db.Decimal(15, 2) // tông tiền trước thuế và chiết khấu unit_cost * quantity
  discount_amount Decimal @default(0) @db.Decimal(15, 2) //  subtotal * (discount_rate / 100)
  tax_amount      Decimal @default(0) @db.Decimal(15, 2) // (subtotal - discount_amount) * (tax_rate / 100)
  total           Decimal @db.Decimal(15, 2) // Thành tiền =  subtotal - discount_amount + tax_amount

  // Ghi chú
  notes String?

  // Relations
  purchase_order       PurchaseOrder        @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade, onUpdate: Cascade) // Đơn hàng
  product              Product              @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Cascade) // Sản phẩm
  variant              Variant              @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: Cascade) // Biến thể
  purchase_return_item PurchaseReturnItem[]

  // Indexes
  @@index([purchase_order_id]) // Index theo đơn hàng
  @@index([product_id]) // Index theo sản phẩm
  @@map("purchase_order_item") // Tên bảng trong database
}

// PurchasePayment: Lịch sử thanh toán cho đơn hàng mua
// Theo dõi các lần thanh toán/trả tiền cho nhà cung cấp
model PurchasePayment {
  // ID
  id String @id @default(uuid()) @db.Uuid // ID duy nhất (UUID)

  // Thông tin thanh toán
  purchase_order_id String  @db.Uuid // ID đơn hàng mua
  unit_cost         Decimal @db.Decimal(15, 2) // Số tiền thanh toán

  payment_method payment_method // Phương thức thanh toán (CASH, CARD, BANK_TRANSFER, etc.)
  payment_date   DateTime       @default(now()) // Ngày thanh toán
  reference      String? // Mã tham chiếu (transaction ID, check number, etc.)
  notes          String? // Ghi chú thêm

  // Thời gian
  createdAt      DateTime      @default(now()) // Ngày tạo
  updatedAt      DateTime?
  // Relations
  purchase_order PurchaseOrder @relation(fields: [purchase_order_id], references: [id], onDelete: Cascade, onUpdate: Cascade) // Đơn hàng

  // Indexes
  @@index([purchase_order_id]) // Index theo đơn hàng
  @@map("purchase_payment") // Tên bảng trong database
}

model PurchaseReturn {
  id            String @id @default(uuid()) @db.Uuid
  store_id      String @db.Uuid
  return_number String

  // supplier info
  supplier_id   String  @db.Uuid
  supplier_name String
  supplier_code String?

  // nullable -> cho phép trả kh theo đơn nhập 
  purchase_order_id String?                @db.Uuid
  status            purchase_return_status @default(DRAFT)
  payment_status    payment_status         @default(UNPAID)

  total Decimal @default(0) @db.Decimal(15, 2)

  reason String?
  notes  String?

  created_by  String   @db.Uuid
  return_date DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  store          Store                   @relation(fields: [store_id], references: [id])
  supplier       Supplier                @relation(fields: [supplier_id], references: [id])
  creator        User                    @relation(fields: [created_by], references: [id])
  purchase_order PurchaseOrder?          @relation(fields: [purchase_order_id], references: [id])
  items          PurchaseReturnItem[]
  payments       PurchaseReturnPayment[]

  @@unique([store_id, return_number])
  @@index([supplier_id, status])
  @@index([id, return_number])
  @@map("purchase_return")
}

model PurchaseReturnItem {
  id                 String @id @default(uuid()) @db.Uuid
  purchase_return_id String @db.Uuid

  product_id             String  @db.Uuid
  variant_id             String  @db.Uuid
  // nullable -> nếu trả không theo đơn nhập
  purchase_order_item_id String? @db.Uuid

  item_name String
  quantity  Int

  unit           String? // VD: "Thùng"      
  applied_factor Int? // VD: 24 (Base Unit thì = 1)
  total_base_qty Int? // = inputQuanity * appliedFactor (VD : 48)

  unit_cost      Decimal @db.Decimal(15, 2)
  base_unit_cost Decimal @db.Decimal(15, 2)

  total Decimal @db.Decimal(15, 2)

  reason String?

  // relations
  purchase_return     PurchaseReturn     @relation(fields: [purchase_return_id], references: [id])
  product             Product            @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant             Variant            @relation(fields: [variant_id], references: [id], onDelete: Cascade)
  purchase_order_item PurchaseOrderItem? @relation(fields: [purchase_order_item_id], references: [id])

  @@index([purchase_return_id])
  @@map("purchase_return_item")
}

model PurchaseReturnPayment {
  id String @id @default(uuid()) @db.Uuid

  purchase_return_id String @db.Uuid

  amount         Decimal        @db.Decimal(15, 2)
  payment_method payment_method
  payment_date   DateTime       @default(now())

  reference String?
  notes     String?

  createdAt DateTime @default(now())

  purchase_return PurchaseReturn @relation(fields: [purchase_return_id], references: [id])

  @@index([purchase_return_id])
  @@map("purchase_return_payment")
}

model StatisticsDaily {
  id        String   @id @default(uuid()) @db.Uuid
  stat_date DateTime @default(now())
  store_id  String   @db.Uuid

  // Orders & revenue (from orders)
  orders_count           Int @default(0)
  paid_orders_count      Int @default(0)
  cancelled_orders_count Int @default(0)
  refunded_orders_count  Int @default(0)

  gross_revenue   Decimal @default(0.00) // sum(subtotal_amount) of orders (all status except CANCELLED)
  discounts_total Decimal @default(0.00) // sum(discount_amount)
  tax_total       Decimal @default(0.00) // sum(tax_amount)
  net_revenue     Decimal @default(0.00) // gross_revenue - discounts_total + tax_total (for valid orders, e.g. PAID/REFUNDED)

  // Stock & sales by unit (from stock_movements)
  units_sold      Int @default(0) // =-SUM(quantity) where type=SALE
  units_returned  Int @default(0) // =SUM(quantity) where type=RETURN_IN
  stock_in_units  Int @default(0) // Stock in units
  stock_out_units Int @default(0) // Stock out units
  stock_net_units Int @default(0) // stock_in_units - stock_out_units (total stock units)

  // Product
  product_created Int @default(0) // number of product created in the day
  active_product  Int @default(0) // snapshot at the end of the day

  // Note: Daily KPIs; sum from orders and stock_movements, no need order_items

  // relations
  store Store @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // indexes
  @@index([store_id])
  @@index([stat_date])
  @@map("statistics_daily")
}

// CashTransaction: Quản lý phiếu thu/phiếu chi
model CashTransaction {
  id   String @id @default(uuid()) @db.Uuid
  code String // PT00001, PC00001

  store_id           String             @db.Uuid
  transaction_type   transaction_type // RECEIPT hoặc PAYMENT
  transaction_source transaction_source

  amount         Decimal        @db.Decimal(15, 2)
  payment_method payment_method

  reference_type TransactionReferenceType?
  reference_id   String?                   @db.Uuid
  reference_code String?

  contact_type contact_type?
  contact_id   String?       @db.Uuid
  contact_name String?

  description String
  notes       String?

  status           transaction_status @default(PENDING)
  transaction_date DateTime           @default(now())

  created_by   String  @db.Uuid
  approved_by  String? @db.Uuid
  cancelled_by String? @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([store_id, transaction_date])
  @@index([store_id, transaction_type])
  @@index([store_id, code])
  @@index([reference_type, reference_id])
  @@index([contact_type])
  @@map("cash_transaction")
}

// CashBookEntry: Sổ quỹ tiền mặt
model CashBookEntry {
  id       String @id @default(uuid()) @db.Uuid
  store_id String @db.Uuid

  date DateTime

  opening_balance Decimal @db.Decimal(15, 2)
  total_receipts  Decimal @db.Decimal(15, 2)
  total_payments  Decimal @db.Decimal(15, 2)
  closing_balance Decimal @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@unique([store_id, date])
  @@index([store_id, date])
  @@map("cash_book_entry")
}

/// File / Tài nguyên được upload vào hệ thống
model Asset {
  id              String            @id @default(uuid()) @db.Uuid
  store_id        String            @db.Uuid
  original_name   String                                        /// Tên file gốc từ client
  filename        String                                        /// Tên file sau khi lưu trữ (unique)
  mime_type       String                                        /// MIME type: image/png, application/pdf...
  size            Int                                           /// Kích thước file (bytes)
  path            String                                        /// Đường dẫn tương đối từ storage root
  access_type     asset_access_type @default(PUBLIC)           /// PUBLIC / PRIVATE / TEMP
  type            asset_type        @default(OTHER)            /// IMAGE / VIDEO / AUDIO / DOCUMENT / OTHER
  folder          String?                                       /// Thư mục con do client chỉ định
  metadata        Json?                                         /// Metadata bổ sung (duration cho audio, v.v.)
  is_deleted      Boolean           @default(false)            /// Soft delete
  uploaded_by_id  String?           @db.Uuid                  /// ID user upload (null nếu do hệ thống tạo)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  store           Store             @relation(fields: [store_id], references: [id], onDelete: Cascade)
  uploaded_by     User?             @relation(fields: [uploaded_by_id], references: [id])
  links           AssetLink[]       /// Danh sách entity được gắn với file này

  @@index([store_id])
  @@index([access_type])
  @@index([type])
  @@index([uploaded_by_id])
  @@index([is_deleted])
  @@index([created_at])
  @@map("asset")
}

/// Liên kết file với entity nghiệp vụ (polymorphic association)
model AssetLink {
  id          String   @id @default(uuid()) @db.Uuid
  store_id    String   @db.Uuid
  asset_id    String   @db.Uuid
  entity_id   String   @db.Uuid                      /// ID của entity (product, order, user...)
  entity_type String                                  /// Tên entity: "product", "order", "user"...
  created_at  DateTime @default(now())

  asset       Asset    @relation(fields: [asset_id], references: [id], onDelete: Cascade)

  @@unique([asset_id, entity_id, entity_type])
  @@index([store_id])
  @@index([entity_id, entity_type])
  @@map("asset_link")
}



// ==========================================
// BUNDLE MODELS
// ==========================================
model Bundle {
  id        String       @id @default(uuid()) @db.Uuid
  name      String       
  quantity  Int       
  sku       String       
  storeId   String       @db.Uuid
  price     Decimal
  store     Store        @relation(fields: [storeId], references: [id])
  items     BundleItem[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([sku, storeId])
  @@unique([name, storeId])
  @@map("bundles")
}

model BundleItem {
  id        String   @id @default(uuid()) @db.Uuid
  variant_name String
  quantity  Int // Số lượng Variant
  bundleId  String   @db.Uuid
  variantId String   @db.Uuid
  bundle    Bundle   @relation(fields: [bundleId], references: [id])
  variant   Variant  @relation(fields: [variantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bundle_items")
}

model Feedback {
  id          String  @id @default(uuid()) @db.Uuid
  store_id    String? @db.Uuid // The store context of the feedback
  title       String
  content     String  @db.Text

  // Sender Info (optional/backup info)
  senderName    String?
  senderPhone   String?
  senderAddress String?

  // Status & Workflow
  status       FeedbackStatus @default(PROCESSING)
  rejectReason String?

  // Satisfaction Rating (filled by user after completion)
  satisfactionRating SatisfactionRating?
  ratedAt            DateTime?

  // Relations
  userId       String? @db.Uuid // The POS user who submitted
  assignedToId String? @db.Uuid // The Super Admin handling it

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  store      Store?            @relation(fields: [store_id], references: [id])
  user       User?             @relation("UserFeedback", fields: [userId], references: [id])
  assignedTo User?             @relation("AdminFeedback", fields: [assignedToId], references: [id])
  comments   FeedbackComment[]

  @@index([userId])
  @@index([status])
  @@map("feedback")
}

model FeedbackComment {
  id         String        @id @default(uuid()) @db.Uuid
  content    String        @db.Text
  feedbackId String        @db.Uuid
  userId     String?       @db.Uuid // Author of the comment
  type       CommenterType @default(USER)
  isAdmin    Boolean       @default(false)
  createdAt  DateTime      @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])

  @@index([feedbackId])
  @@map("feedback_comment")
}

/**
 * Notification model
 * Represents a single notification event (admin push or system-generated)
 * Each user who receives it gets a UserNotification row to track read status
 */
model Notification {
  id           String                   @id @default(uuid()) @db.Uuid
  title        String
  content      String                   @db.Text
  type         notification_type        @default(SYSTEM)
  target_type  notification_target_type @default(ALL)
  target_role  user_role?               // Set when target_type = ROLE
  metadata     Json                     @default("{}")  // Extra context (e.g. orderId, storeId)
  created_by   String?                  @db.Uuid        // null = system-generated
  scheduled_at DateTime?                // null = send immediately
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  creator            User?              @relation("NotificationCreator", fields: [created_by], references: [id], onDelete: SetNull)
  user_notifications  UserNotification[]

  @@index([type])
  @@index([created_by])
  @@index([createdAt])
  @@map("notification")
}

/**
 * UserNotification model
 * Per-user tracking of notification delivery and read status
 */
model UserNotification {
  id              String   @id @default(uuid()) @db.Uuid
  notification_id String   @db.Uuid
  user_id         String   @db.Uuid
  is_read         Boolean  @default(false)
  read_at         DateTime?
  createdAt       DateTime @default(now())

  notification Notification @relation(fields: [notification_id], references: [id], onDelete: Cascade)
  user         User         @relation("UserNotifications", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([notification_id, user_id])
  @@index([user_id, is_read])
  @@index([notification_id])
  @@map("user_notification")
}
