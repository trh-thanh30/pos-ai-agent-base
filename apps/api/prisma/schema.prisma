  quantity          Int
  quantity_refunded Int     @default(0) // snap shot các lần trả
  total             Decimal @db.Decimal(15, 2)

  reason_status order_item_return_reason @default(UNKNOWN)
  condition     String? // Tình trạng hàng (ví dụ: còn nguyên seal, đã bóc hộp)      

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order_return OrderReturn @relation(fields: [order_return_id], references: [id], onDelete: Cascade)
  order_item   OrderItem   @relation(fields: [order_item_id], references: [id], onDelete: Cascade)
  variant      Variant     @relation(fields: [variant_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  product      Product     @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([order_return_id])
  @@index([variant_id])
  @@index([product_id])
  @@map("order_return_item")
}

model OrderReturnPayment {
  // ID
  id String @id @default(uuid()) @db.Uuid // ID duy nhất (UUID)

  // Thông tin thanh toán
  order_return_id String  @db.Uuid // ID đơn
  amount          Decimal @db.Decimal(15, 2) // Số tiền thanh toán

  payment_method payment_method // Phương thức thanh toán (CASH, CARD, BANK_TRANSFER, etc.)
  payment_date   DateTime       @default(now()) // Ngày thanh toán
  reference      String? // Mã tham chiếu (transaction ID, check number, etc.)
  notes          String? // Ghi chú thêm

  // Thời gian
  createdAt    DateTime    @default(now()) // Ngày tạo
  updatedAt    DateTime?
  // Relations
  order_return OrderReturn @relation(fields: [order_return_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // Indexes
