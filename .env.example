# =========================================================================
# GLOBAL ENVIRONMENT SETTINGS
# =========================================================================
NODE_ENV=development
TZ=Asia/Ho_Chi_Minh
COMPOSE_PROJECT_NAME=pos-system


# =========================================================================
# BACKEND (API) CONFIGURATION
# =========================================================================
APP_NAME="POS System API"
APP_VERSION="1.0.0"
API_PORT=4100
PORT=${API_PORT}
BE_PORT=${API_PORT}
BACKEND_URL="http://localhost:4100"
PUBLIC_API_URL="http://localhost:4100/api/v1"

# Security & Auth
JWT_ACCESS_SECRET=your_super_secret_access_jwt_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_jwt_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# Storage & Uploads
STORAGE_DRIVER=local
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=10485760
STORAGE_ROOT_DIR=./storage
STORAGE_PUBLIC_DIR_NAME=public
STORAGE_PRIVATE_DIR_NAME=private
STORAGE_TEMP_DIR_NAME=temp
MINIO_ENDPOINT=localhost
MINIO_PORT=19000
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_PUBLIC=pos-system-public
MINIO_BUCKET_PRIVATE=pos-system-private
MINIO_BUCKET_TEMP=pos-system-temp
MINIO_CONSOLE_PORT=19001
ASSET_CDN_URL="http://localhost:19000/pos-system-public"
ASSET_MAX_FILE_SIZE=10485760
ASSET_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,image/svg+xml,video/mp4,video/quicktime,audio/mpeg,audio/wav,application/pdf

# =========================================================================
# FRONTEND (MAIN WEB) CONFIGURATION
# =========================================================================
WEB_MAIN_PORT=4101
WEB_PORT=${WEB_MAIN_PORT}
FE_PORT=${WEB_MAIN_PORT}
FRONTEND_URL="http://localhost:4101"
NEXT_ASSET_API_URL="http://localhost:4100/uploads/public/"
NEXT_PUBLIC_API_URL="http://localhost:4100/api/v1"

# =========================================================================
# FRONTEND (RETAIL WEB) CONFIGURATION
# =========================================================================
WEB_RETAIL_PORT=4102
ADMIN_PORT=${WEB_RETAIL_PORT}
WEB_RETAIL_URL="http://localhost:4102"
NEXT_ASSET_API_URL="http://localhost:4100/uploads/public/"
NEXT_PUBLIC_API_URL="http://localhost:4100/api/v1"

# =========================================================================
# DATABASE (POSTGRESQL) CONFIGURATION
# =========================================================================
DB_HOST=localhost
DB_PORT=15433
DB_USER=pos_user
DB_PASSWORD=pos_password
DB_NAME=pos_db
DB_SCHEMA=public

# Standardized DATABASE_URL
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=${DB_SCHEMA}

# Docker Database Config (Keep in sync with variables above)
POSTGRES_USER=pos_user
POSTGRES_PASSWORD=pos_password
POSTGRES_DB=pos_db
DEV_DB_PORT=15433
PROD_DB_PORT=25433

# =========================================================================
# CACHE (REDIS) CONFIGURATION
# =========================================================================
REDIS_HOST=localhost
REDIS_DEV_PORT=6319
REDIS_PASSWORD=pos_redis_password
REDIS_DB_PORT=6319

# Standardized REDIS_URL
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_DEV_PORT}

# =========================================================================
# EMAIL (SMTP) CONFIGURATION
# =========================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="${APP_NAME} Agent <no-reply@example.com>"
EMAIL_FROM="${APP_NAME} <${SMTP_USER}>"
EMAIL_TEMPLATES_PATH=src/module/email/templates

# =========================================================================
# THIRD-PARTY SERVICES & OAUTH
# =========================================================================

# Google OAuth
GOOGLE_CLIENT_ID="GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="GOOGLE_CLIENT_SECRET"
GOOGLE_REDIRECT_URI="http://localhost:4100/api/v1/auth/google/callback"

# =========================================================================
# MONITORING & LOGGING
# =========================================================================
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=5
PROMETHEUS_ENABLED=false
METRICS_PORT=19090
HEALTH_ENDPOINTS_ENABLED=false

# =========================================================================
# TELEGRAM NOTIFICATIONS - CI/CD
# =========================================================================
CI_TELEGRAM_BOT_TOKEN=
CI_TELEGRAM_CHAT_ID=

# =========================================================================
# CONTAINER IMAGES - CD
# =========================================================================
API_IMAGE=ghcr.io/owner/repository-pos-system-api
WEB_MAIN_IMAGE=ghcr.io/owner/repository-pos-system-web-main
WEB_RETAIL_IMAGE=ghcr.io/owner/repository-pos-system-web-retail
WORKER_EMAIL_IMAGE=ghcr.io/owner/repository-pos-system-worker-email
WORKER_TELEGRAM_IMAGE=ghcr.io/owner/repository-pos-system-worker-telegram
IMAGE_TAG=latest

# =========================================================================
# PRODUCTION BACKUPS
# =========================================================================
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
BACKUP_TELEGRAM_ENABLED=true

# =========================================================================
# GRAFANA CONFIGURATION
# =========================================================================
GRAFANA_PORT=4103
GRAFANA_ADMIN_USER=pos_admin
GRAFANA_ADMIN_PASSWORD=pos_grafana_change_me
GRAFANA_LOG_LEVEL=info

# =========================================================================
# NETWORK & CORS
# =========================================================================
CORS_ORIGINS="http://localhost:4100,http://localhost:4101,http://localhost:4102"
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# =========================================================================
# COOKIE
# =========================================================================
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax
COOKIE_PARTITIONED=false
COOKIE_MAX_AGE=604800000
COOKIE_PATH=/
