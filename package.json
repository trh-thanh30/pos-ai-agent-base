{
  "name": "pos-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Multi-domain POS system monorepo",
  "workspaces": [
    "apps/api",
    "apps/web/*",
    "apps/worker/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "turbo run dev",
    "dev:apps": "turbo run dev --filter=@pos/web-main --filter=@pos/web-retail",
    "dev:full": "turbo run dev --filter=@pos/api --filter=@pos/web-main --filter=@pos/web-retail",
    "dev:api": "pnpm --filter @pos/api start:dev",
    "dev:api:debug": "pnpm --filter @pos/api start:debug",
    "dev:web": "pnpm --filter @pos/web-main dev",
    "dev:admin": "pnpm --filter @pos/web-retail dev",
    "dev:docs": "pnpm --filter @pos/docs start",
    "build": "turbo run build",
    "build:all": "turbo run build",
    "build:apps": "turbo run build --filter=@pos/web-main --filter=@pos/web-retail",
    "build:packages": "turbo run build --filter=@repo/*",
    "build:api": "pnpm --filter @pos/api build",
    "build:web": "pnpm --filter @pos/web-main build",
    "build:admin": "pnpm --filter @pos/web-retail build",
    "build:docs": "pnpm --filter @pos/docs build",
    "start:api": "pnpm --filter @pos/api start:prod",
    "start:web": "pnpm --filter @pos/web-main start",
    "start:admin": "pnpm --filter @pos/web-retail start",
    "start:docs": "pnpm --filter @pos/docs serve",
    "start:worker": "pnpm start:worker:email",
    "start:worker:email": "pnpm --filter @pos/worker-email start",
    "start:worker:telegram": "pnpm --filter @pos/worker-telegram start",
    "lint": "turbo run lint",
    "lint:all": "turbo run lint",
    "lint:api": "pnpm --filter @pos/api lint",
    "lint:web": "pnpm --filter @pos/web-main lint",
    "lint:admin": "pnpm --filter @pos/web-retail lint",
    "lint:docs": "echo \"@pos/docs has no lint script\"",
    "lint:hooks": "echo \"@repo/hooks workspace is not present in this repository\"",
    "lint:packages": "turbo run lint --filter=@repo/*",
    "check-types": "turbo run type-check",
    "type-check": "turbo run type-check",
    "typecheck": "turbo run type-check",
    "typecheck:api": "pnpm --filter @pos/api type-check",
    "typecheck:web": "pnpm --filter @pos/web-main type-check",
    "typecheck:admin": "pnpm --filter @pos/web-retail type-check",
    "typecheck:docs": "pnpm --filter @pos/docs typecheck",
    "typecheck:hooks": "echo \"@repo/hooks workspace is not present in this repository\"",
    "typecheck:packages": "turbo run type-check --filter=@repo/*",
    "typecheck:workers": "turbo run type-check --filter=@pos/worker-*",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "test": "turbo run test",
    "test:all": "turbo run test",
    "test:api": "pnpm --filter @pos/api test",
    "test:api:dev": "pnpm --filter @pos/api test",
    "test:api:prod": "pnpm --filter @pos/api test",
    "test:api:watch": "pnpm --filter @pos/api test:watch",
    "test:api:cov": "pnpm --filter @pos/api test:cov",
    "test:api:e2e": "pnpm --filter @pos/api test:e2e",
    "test:api:debug": "pnpm --filter @pos/api test:debug",
    "worker:dev": "pnpm worker:email:dev",
    "worker:prod": "pnpm worker:email:prod",
    "worker:email:dev": "pnpm --filter @pos/worker-email dev",
    "worker:email:prod": "pnpm --filter @pos/worker-email start",
    "worker:telegram:dev": "pnpm --filter @pos/worker-telegram dev",
    "worker:telegram:prod": "pnpm --filter @pos/worker-telegram start",
    "infra:dev:up": "docker compose -f docker-compose.dev.yml --env-file .env.development up -d db redis minio minio-init",
    "infra:dev:down": "docker compose -f docker-compose.dev.yml --env-file .env.development down",
    "infra:dev:logs": "docker compose -f docker-compose.dev.yml --env-file .env.development logs -f",
    "infra:dev:ps": "docker compose -f docker-compose.dev.yml --env-file .env.development ps",
    "infra:dev:config": "docker compose -f docker-compose.dev.yml --env-file .env.development config",
    "infra:prod:up": "docker compose -f docker-compose.prod.yml --env-file .env.production up -d",
    "infra:prod:down": "docker compose -f docker-compose.prod.yml --env-file .env.production down",
    "infra:prod:logs": "docker compose -f docker-compose.prod.yml --env-file .env.production logs -f",
    "infra:prod:ps": "docker compose -f docker-compose.prod.yml --env-file .env.production ps",
    "infra:prod:config": "docker compose -f docker-compose.prod.yml --env-file .env.production config",
    "docker:build:api": "docker build -f apps/api/Dockerfile --target runner -t pos-system-api:latest .",
    "docker:build:web": "docker build -f apps/web/main/Dockerfile -t pos-system-web-main:latest .",
    "docker:build:admin": "docker build -f apps/web/retail/Dockerfile -t pos-system-web-retail:latest .",
    "docker:build:worker-email": "docker build -f apps/worker/email/Dockerfile -t pos-system-worker-email:local .",
    "docker:build:worker-telegram": "docker build -f apps/worker/telegram/Dockerfile -t pos-system-worker-telegram:local .",
    "docker:build:web-main": "pnpm docker:build:web",
    "docker:build:web-retail": "pnpm docker:build:admin",
    "docker:build:all": "pnpm docker:build:api && pnpm docker:build:web && pnpm docker:build:admin && pnpm docker:build:worker-email && pnpm docker:build:worker-telegram",
    "docker:check:api": "docker build --check -f apps/api/Dockerfile .",
    "docker:check:web": "docker build --check -f apps/web/main/Dockerfile .",
    "docker:check:admin": "docker build --check -f apps/web/retail/Dockerfile .",
    "docker:check:worker-email": "docker build --check -f apps/worker/email/Dockerfile .",
    "docker:check:worker-telegram": "docker build --check -f apps/worker/telegram/Dockerfile .",
    "docker:check:all": "pnpm docker:check:api && pnpm docker:check:web && pnpm docker:check:admin && pnpm docker:check:worker-email && pnpm docker:check:worker-telegram",
    "docker:check:dev": "docker compose -f docker-compose.dev.yml --env-file .env.example config",
    "docker:check:prod": "docker compose -f docker-compose.prod.yml --env-file .env.example config",
    "notify:telegram": "pnpm --filter @repo/telegram notify",
    "prisma:generate": "pnpm --filter @pos/api prisma:generate",
    "prisma:studio": "pnpm --filter @pos/api prisma:studio",
    "prisma:studio:dev": "pnpm --filter @pos/api prisma:studio",
    "prisma:migrate": "pnpm --filter @pos/api prisma:migrate",
    "prisma:migrate:dev": "pnpm --filter @pos/api prisma:migrate",
    "prisma:migrate:prod": "dotenv -e .env.production -- pnpm --filter @pos/api exec prisma migrate deploy",
    "prisma:migrate:reset:dev": "pnpm --filter @pos/api prisma:migrate:reset:dev",
    "prisma:migrate:reset:force": "pnpm --filter @pos/api prisma:migrate:reset:force",
    "db:push": "pnpm --filter @pos/api db:push:dev",
    "db:push:dev": "pnpm --filter @pos/api db:push:dev",
    "db:push:test": "pnpm --filter @pos/api db:push:test",
    "db:push:prod": "pnpm --filter @pos/api db:push:prod",
    "db:seed:dev": "pnpm --filter @pos/api db:seed:dev",
    "db:seed:test": "pnpm --filter @pos/api db:seed:test",
    "db:seed:prod": "pnpm --filter @pos/api db:seed:prod",
    "db:reset:dev": "pnpm --filter @pos/api prisma:migrate:reset:dev",
    "dev:all": "pnpm dev:full",
    "dev:frontend": "pnpm dev:apps",
    "dev:frontend:main": "pnpm dev:web",
    "dev:frontend:retail": "pnpm dev:admin",
    "dev:backend": "pnpm dev:api",
    "dev:workers": "turbo run dev --parallel --filter=@pos/worker-*",
    "dev:worker:email": "pnpm worker:email:dev",
    "build:tui": "cross-env NODE_OPTIONS=--max-old-space-size=8192 turbo run build --concurrency=1 --ui=tui",
    "build:backend": "pnpm build:api",
    "build:web-main": "pnpm build:web",
    "build:web-retail": "pnpm build:admin",
    "build:workers": "turbo run build --filter=@pos/worker-*",
    "lint:fix": "turbo run lint:fix",
    "lint:web-main": "pnpm lint:web",
    "lint:web-retail": "pnpm lint:admin",
    "typecheck:web-main": "pnpm typecheck:web",
    "typecheck:web-retail": "pnpm typecheck:admin",
    "test:watch": "turbo run test:watch",
    "clean": "turbo run clean",
    "clean:all": "turbo run clean && rm -rf node_modules",
    "reset": "pnpm run clean:all && pnpm install",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=@repo/* && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/file-saver": "^2.0.7",
    "@types/html2pdf.js": "^0.10.0",
    "@types/jsbarcode": "^3.11.3",
    "@types/lodash.isequal": "^4.5.0",
    "@types/node": "^20.11.24",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "prettier": "^3.2.5",
    "tailwind-scrollbar": "^4.0.2",
    "turbo": "^2.2.3",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "dependencies": {
    "@mantine/charts": "^8.2.5",
    "@mantine/code-highlight": "^8.2.5",
    "@mantine/core": "^8.2.5",
    "@mantine/dates": "^8.2.5",
    "@mantine/dropzone": "^8.2.5",
    "@mantine/form": "^8.2.5",
    "@mantine/hooks": "^8.2.5",
    "@mantine/modals": "^8.2.5",
    "@mantine/notifications": "^8.2.5",
    "@mantine/tiptap": "^8.2.5",
    "@react-pdf/renderer": "^4.3.1",
    "@tiptap/extension-link": "^3.2.0",
    "@tiptap/pm": "^3.2.0",
    "@tiptap/react": "^3.2.0",
    "@tiptap/starter-kit": "^3.2.0",
    "cross-env": "^10.0.0",
    "dayjs": "^1.11.13",
    "file-saver": "^2.0.5",
    "html2pdf.js": "^0.12.1",
    "next": "^14.2.31",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-to-print": "^3.2.0",
    "recharts": "^2.15.4",
    "tailwind-scrollbar": "^4.0.2",
    "xlsx": "^0.18.5"
  }
}
